            "id": "minio",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "RELEASE.2024-12-18T13-15-44Z",
                "chart": "minio",
                "first_deployed": 1773590519,
                "last_deployed": 1773590519,
                "name": "minio",
                "namespace": "mlflow",
                "notes": "\nMinIO can be accessed via port 9000 on the following DNS name from within your cluster:\nminio.mlflow.cluster.local\n\nTo access MinIO from localhost, run the below commands:\n\n  1. export POD_NAME=$(kubectl get pods --namespace mlflow -l \"release=minio\" -o jsonpath=\"{.items[0].metadata.name}\")\n\n  2. kubectl port-forward $POD_NAME 9000 --namespace mlflow\n\nRead more about port forwarding here: http://kubernetes.io/docs/user-guide/kubectl/kubectl_port-forward/\n\nYou can now access MinIO server on http://localhost:9000. Follow the below steps to connect to MinIO server with mc client:\n\n  1. Download the MinIO mc client - https://min.io/docs/minio/linux/reference/minio-mc.html#quickstart\n\n  2. export MC_HOST_minio-local=http://$(kubectl get secret --namespace mlflow minio -o jsonpath=\"{.data.rootUser}\" | base64 --decode):$(kubectl get secret --namespace mlflow minio -o jsonpath=\"{.data.rootPassword}\" | base64 --decode)@localhost:9000\n\n  3. mc ls minio-local\n\n\n",
                "revision": 1,
                "values": "{\"buckets\":[{\"name\":\"mlflow\",\"policy\":\"none\"}],\"mode\":\"standalone\",\"resources\":{\"requests\":{\"memory\":\"512Mi\"}},\"rootPassword\":\"minioadmin123\",\"rootUser\":\"minioadmin\"}",
                "version": "5.4.0"
              }
            ],
            "name": "minio",
            "namespace": "mlflow",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
