            "metadata": [
              {
                "app_version": "3.7.0",
                "chart": "mlflow",
                "first_deployed": 1773590548,
                "last_deployed": 1773592026,
                "name": "mlflow",
                "namespace": "mlflow",
                "notes": "1. Get the application URL by running these commands:\n  export POD_NAME=$(kubectl get pods --namespace mlflow -l \"app.kubernetes.io/name=mlflow,app.kubernetes.io/instance=mlflow\" -o jsonpath=\"{.items[0].metadata.name}\")\n  export CONTAINER_PORT=$(kubectl get pod --namespace mlflow $POD_NAME -o jsonpath=\"{.spec.containers[0].ports[0].containerPort}\")\n  echo \"Visit http://127.0.0.1:8080 to use your application\"\n  kubectl --namespace mlflow port-forward $POD_NAME 8080:$CONTAINER_PORT\n",
                "revision": 2,
                "values": "{\"artifactRoot\":{\"s3\":{\"awsAccessKeyId\":\"minioadmin\",\"awsSecretAccessKey\":\"minioadmin123\",\"bucket\":\"mlflow\",\"enabled\":true}},\"backendStore\":{\"postgres\":{\"database\":\"mlflow\",\"enabled\":true,\"host\":\"postgresql.mlflow.svc.cluster.local\",\"password\":\"mlflow123\",\"port\":5432,\"user\":\"mlflow\"}},\"extraArgs\":{\"gunicorn-opts\":\"--forwarded-allow-ips=*\"},\"extraEnvVars\":{\"GUNICORN_CMD_ARGS\":\"--forwarded-allow-ips=*\",\"MLFLOW_ALLOW_FILESTORE_ARTIFACT_DOWNLOADS\":true,\"MLFLOW_S3_ENDPOINT_URL\":\"http://minio.mlflow.svc.cluster.local:9000\"}}",
